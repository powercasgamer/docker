# User/Group settings
PUID=1000
PGID=1000
TZ=Europe/Amsterdam

# Application paths
DATA_FOLDER=/opt/gluetun/data

# VPN provider settings
VPN_SERVICE=mullvad
VPN_TYPE=wireguard
SERVER_COUNTRIES=Netherlands

# WireGuard configuration
WIREGUARD_PRIVATE_KEY=your_private_key_here
WIREGUARD_ADDRESSES=your_wireguard_ip/32

# Port configurations
GLUETUN_WEBUI_PORT=8888
QBITTORRENT_WEBUI_PORT=9091
TORRENT_P2P_PORT=51413
SONARR_PORT=8989
RADARR_PORT=7878
BAZARR_PORT=6767
JELLYFIN_PORT=8096
JELLYSEERR_PORT=5055
HUNTARR_PORT=9705

# Domain configurations
DOMAIN=yourdomain.com

# Homepage configuration
HOMEPAGE_API_KEY=your_homepage_api_key_here